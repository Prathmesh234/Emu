# ── Provider Selection ────────────────────────────────────────────────────────
# Options: claude | openai | openrouter | gemini | openai_compatible | modal
#          azure_openai | bedrock | fireworks | together_ai | baseten | h_company
EMU_PROVIDER=openrouter

# ── Model request timing ──────────────────────────────────────────────────────
# Seconds to wait for each model call before retrying/failing.
EMU_MODEL_TIMEOUT_SECS=60
# Number of retries after a timed-out model call. Keep low for paid APIs to avoid
# stacking duplicate in-flight requests.
EMU_MODEL_TIMEOUT_RETRIES=1

# ── Emu data directory ────────────────────────────────────────────────────────
# Optional. Defaults to <repo>/.emu (gitignored), matching frontend/emu/init.js.
# Set to e.g. ~/.emu if you want user data outside the clone (product installs).
#EMU_ROOT=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=

# ── OpenAI-Compatible (vLLM / SGLang / Ollama) ────────────────────────────────
OPENAI_BASE_URL=
OPENAI_COMPAT_MODEL=

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=

# ── Modal GPU Endpoints ───────────────────────────────────────────────────────
MODAL_VLM_URL=
OMNIPARSER_PARSE_URL=
OMNIPARSER_HEALTH_URL=

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
OPENROUTER_PROVIDER_NAME=alibaba
OPENROUTER_REQUEST_TIMEOUT_SECS=60

# ── OmniParser ────────────────────────────────────────────────────────────────
USE_OMNI_PARSER=0

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514-v1:0

# ── Fireworks AI ──────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic

# ── Together AI ───────────────────────────────────────────────────────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8

# ── Baseten ───────────────────────────────────────────────────────────────────
BASETEN_API_KEY=
BASETEN_MODEL=moonshotai/Kimi-K2.5

# ── H Company (Holo) ────────────────────────────────────────────────────────
# Set EMU_PROVIDER=h_company. Model defaults to holo3-35b-a3b.
H_COMPANY_API_KEY=
H_COMPANY_MODEL=holo3-35b-a3b

# ── Memory Daemon ─────────────────────────────────────────────────────────────
# Background daemon that curates .emu/ memory files (see daemon/).
# EMU_DAEMON_PROVIDER: which provider the daemon uses (independent of EMU_PROVIDER).
#   Options: claude | openai | openrouter | fireworks | together_ai | openai_compatible | baseten
#   Note: bedrock, gemini, h_company, and modal are not yet supported by the daemon.
# EMU_DAEMON_MODEL: optional override for OpenAI-compatible daemon providers (openrouter, openai,
#   fireworks, together_ai, openai_compatible, baseten). Ignored when EMU_DAEMON_PROVIDER=claude.
# EMU_DAEMON_API_KEY: API key for the daemon's provider. If unset, falls back to
#   the provider's own key env var (e.g. OPENROUTER_API_KEY for openrouter).
#   Can also be stored in macOS Keychain under service name 'com.emu.memory-daemon'.
EMU_DAEMON_PROVIDER=openrouter
EMU_DAEMON_MODEL=openai/gpt-5.4
EMU_DAEMON_API_KEY=
# Seconds between in-process daemon ticks (default 300). Use 30 to verify quickly.
EMU_DAEMON_INTERVAL_SECONDS=300
