; emu-daemon.sb — sandbox-exec profile for the Emu memory daemon (Layer 3).
;
; {{APP_BUNDLE}}, {{EMU_ROOT}}, {{HOME}} are substituted by the Emu app at
; install time before this file is written to the app bundle.
;
; Security model: deny everything by default, then carve out the minimum
; required for Python to start, TLS to work, and .emu/ to be writable.
; File writes are ONLY allowed inside {{EMU_ROOT}}. All other paths are
; read-only at best, denied entirely at worst.

(version 1)
(deny default)

; ── Process execution ────────────────────────────────────────────────────────
; Allow Python and standard Unix tools to exec. No arbitrary binaries.
(allow process-fork)
(allow process-exec
    (subpath "/usr/bin")
    (subpath "/bin")
    (subpath "/usr/local/bin")
    (subpath "/opt/homebrew")
    (subpath "{{APP_BUNDLE}}/Contents/Resources/daemon"))

; ── Read-only filesystem access ──────────────────────────────────────────────
; Python stdlib, dylibs, TLS roots, Homebrew packages, and the app bundle
; are all read-only. No writes allowed to any of these.
(allow file-read*
    (subpath "/usr/lib")
    (subpath "/usr/libexec")
    (subpath "/usr/share")
    (subpath "/System")
    (subpath "/Library/Frameworks")
    (subpath "/Library/Python")
    (subpath "/private/etc")
    (subpath "/opt/homebrew")
    (subpath "{{APP_BUNDLE}}")
    (subpath "{{HOME}}/Library/Caches")
    (subpath "{{HOME}}/.cache"))

; ── The ONLY writable region: the user's .emu directory ─────────────────────
; write_file, state.json, and logs all land here. Nothing else is writable.
(allow file-write*
    (subpath "{{EMU_ROOT}}"))
(allow file-read*
    (subpath "{{EMU_ROOT}}"))

; Note: ~/Library/LaunchAgents/ is intentionally NOT writable.
; The daemon cannot rewrite its own plist or install new launch jobs.

; ── Network ──────────────────────────────────────────────────────────────────
; Allow outbound HTTPS (port 443) to any host — provider endpoints span many
; domains (Anthropic, OpenAI, Fireworks, Together, OpenRouter, etc.) and we
; cannot enumerate them statically. DNS (UDP 53) is required for resolution.
(allow network-outbound
    (remote tcp "*:443")
    (remote udp "*:53"))

; uv / Python may bind a localhost socket during startup
(allow network-bind
    (local ip "localhost:*"))

; Required for resolver, TLS certificate validation, and CoreCrypto
(allow system-socket)
(allow mach-lookup)
(allow sysctl-read)
(allow iokit-open)
