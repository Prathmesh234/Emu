# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# GitHub (optional — raises rate limit from 60/hr → 5000/hr when set)
GITHUB_TOKEN=

# Hugging Face (optional — needed for some gated repos; speeds up downloads)
HF_TOKEN=

# Generation
MAX_TOKENS=8192
TEMPERATURE=0.7
